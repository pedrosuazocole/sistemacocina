<!DOCTYPE html>
<html lang="es-HN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Catálogo - Sistema de Cocina</title>
    <link rel="stylesheet" href="/css/styles.css">
</head>
<body>
    <%- include('partials/sidebar') %>
    
    <main class="main-content">
        <header class="page-header">
            <h1>📋 Catálogo de Artículos</h1>
        </header>
        
        <div class="tabs">
            <button class="tab-btn active" onclick="switchTab('registrar')">Registrar</button>
            <button class="tab-btn" onclick="switchTab('modificar')">Modificar</button>
        </div>
        
        <!-- TAB REGISTRAR -->
        <div id="tab-registrar" class="tab-content active">
            <div class="card">
                <div class="card-header">
                    <h3>Nuevo Artículo</h3>
                </div>
                <div class="card-body">
                    <form id="formNuevoArticulo" onsubmit="crearArticulo(event)">
                        <div class="form-row">
                            <div class="form-group">
                                <label>Nombre del Producto</label>
                                <input type="text" id="nombreNuevo" required>
                            </div>
                            <div class="form-group">
                                <label>Unidad</label>
                                <select id="unidadNueva" required>
                                    <option>Unidad</option>
                                    <option>Libra</option>
                                    <option>Kg</option>
                                    <option>Litro</option>
                                    <option>Onza</option>
                                    <option>Gramo</option>
                                </select>
                            </div>
                        </div>
                        <button type="submit" class="btn btn-primary">Guardar</button>
                    </form>
                </div>
            </div>
        </div>
        
        <!-- TAB MODIFICAR -->
        <div id="tab-modificar" class="tab-content">
            <div class="card">
                <div class="card-header">
                    <h3>Modificar Artículo</h3>
                </div>
                <div class="card-body">
                    <table class="table">
                        <thead>
                            <tr>
                                <th>Código</th>
                                <th>Nombre</th>
                                <th>Unidad</th>
                                <th>Acciones</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% catalogo.forEach(art => { %>
                            <tr>
                                <td><%= art.codigo %></td>
                                <td><%= art.nombre %></td>
                                <td><%= art.unidad %></td>
                                <td>
                                    <button class="btn btn-sm" onclick="editarArticulo(<%= art.id %>)">
                                        ✏️ Editar
                                    </button>
                                </td>
                            </tr>
                            <% }); %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </main>
    
    <script src="/js/main.js"></script>
    <script src="/js/catalogo.js"></script>
</body>
</html>
